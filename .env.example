# Voice dispatcher (required for speech) — your Gemini Developer API key
GEMINI_API_KEY=

# Agent executor model override (optional; default = your Claude Code default)
# DISPATCH_MODEL=claude-sonnet-4-6

# MCP gate: Bright Data + VideoDB-as-a-tool load as MCP servers that BLOCK the
# agent's boot until they connect over the network. Left OFF by default so the
# core speak->act loop always boots fast and can't be hung by a flaky network.
# Set to "on" AFTER pre-warming on your demo network to enable the Bright Data
# web beat + VideoDB eyes-as-a-tool. (VideoDB vision via the RTStream webhook
# works either way — it is not an MCP server.)
# DISPATCH_MCP=on

# Sponsor: Bright Data live-web MCP (get.brightdata.com/aibuilders10)
# BRIGHTDATA_API_TOKEN=

# Sponsor: VideoDB "eyes" — MCP vision tool (Path A) + RTStream webhook dispatch
# (Path B). One key powers both. Get $520 unified credits at videodb.io.
# VIDEODB_API_KEY=

# Sponsor: Kimi k2.6 executor mode (theaibuilders.dev/kimicredits)
# DISPATCH_EXECUTOR=kimi
# KIMI_API_KEY=
